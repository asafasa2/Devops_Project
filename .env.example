# DevOps Practice Environment Configuration
# Copy this file to .env and customize for your environment

# Environment Configuration
ENVIRONMENT=dev
NODE_ENV=development
FLASK_ENV=development
SPRING_PROFILES_ACTIVE=development

# Database Configuration
DB_PASSWORD=dev_password_2024
POSTGRES_MEMORY_LIMIT=512m
POSTGRES_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=128m
REDIS_CPU_LIMIT=0.5

# Application Configuration
JWT_SECRET=dev_jwt_secret_key_2024
LOG_LEVEL=info

# Service Images and Tags
API_GATEWAY_IMAGE=devops-practice/api-gateway
API_GATEWAY_TAG=latest
LEARNING_SERVICE_IMAGE=devops-practice/learning-service
LEARNING_SERVICE_TAG=latest
USER_SERVICE_IMAGE=devops-practice/user-service
USER_SERVICE_TAG=latest
ASSESSMENT_SERVICE_IMAGE=devops-practice/assessment-service
ASSESSMENT_SERVICE_TAG=latest
LAB_SERVICE_IMAGE=devops-practice/lab-service
LAB_SERVICE_TAG=latest
FRONTEND_IMAGE=devops-practice/frontend
FRONTEND_TAG=latest

# Service Ports
API_GATEWAY_PORT=4000
LEARNING_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
LAB_SERVICE_PORT=4003
ASSESSMENT_SERVICE_PORT=4004
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# Service Resource Limits
API_GATEWAY_MEMORY_LIMIT=512m
API_GATEWAY_CPU_LIMIT=1.0
LEARNING_SERVICE_MEMORY_LIMIT=512m
LEARNING_SERVICE_CPU_LIMIT=1.0
USER_SERVICE_MEMORY_LIMIT=512m
USER_SERVICE_CPU_LIMIT=1.0
ASSESSMENT_SERVICE_MEMORY_LIMIT=512m
ASSESSMENT_SERVICE_CPU_LIMIT=1.0
LAB_SERVICE_MEMORY_LIMIT=1g
LAB_SERVICE_CPU_LIMIT=2.0
FRONTEND_MEMORY_LIMIT=256m
FRONTEND_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=128m
NGINX_CPU_LIMIT=0.5

# Frontend Configuration
REACT_APP_API_URL=http://localhost:4000
REACT_APP_ENVIRONMENT=development

# Monitoring Configuration
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_SECRET_KEY=SW2YcwTIb9zpOOhoPsMm
JENKINS_ADMIN_PASSWORD=admin123
