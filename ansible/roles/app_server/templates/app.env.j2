# Application environment configuration
ENVIRONMENT={{ environment }}
NODE_ENV={{ environment }}

# Database configuration
DB_HOST={{ hostvars[groups['db_servers'][0]]['ansible_host'] }}
DB_PORT=5432
DB_NAME=devops_practice
DB_USER=devops_user
DB_PASSWORD={{ db_password | default('default_password') }}

# Redis configuration
REDIS_HOST={{ hostvars[groups['db_servers'] | select('match', '.*redis.*') | list | first]['ansible_host'] }}
REDIS_PORT=6379

# Service configuration
SERVICE_PORT={{ service_port | default(8080) }}
LOG_LEVEL={{ log_level | default('info') }}

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090